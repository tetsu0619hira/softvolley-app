rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /matches/{matchId} {
      allow read, write: if true;
    }

    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /teams/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
